# Copia questo file in ".env" e compila i valori reali prima del deploy.
# NON caricare mai il file ".env" vero su GitHub.

# Stringa di connessione al database Postgres (te la dà l'hosting: Render, Railway, Supabase...)
DATABASE_URL=postgresql+psycopg2://utente:password@host:5432/nomedb

# Segreto per firmare i token di sessione — genera una stringa lunga e casuale,
# per esempio con: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CAMBIA-QUESTO-CON-UNA-STRINGA-CASUALE-LUNGA

# Domini autorizzati a chiamare l'API (il tuo sito, quando lo pubblichi)
CORS_ORIGINS=https://TUO-DOMINIO.it

# URL base usato nei link delle email (es. di reset password)
APP_BASE_URL=https://TUO-DOMINIO.it

# Invio email: "log" stampa il link nei log invece di inviarlo (va bene per i test).
# Passa a "smtp" con le credenziali del tuo provider (es. Brevo, Mailgun, Gmail con
# password per le app) per inviare email vere.
EMAIL_PROVIDER=log
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# con dedizione da Lorenzo
